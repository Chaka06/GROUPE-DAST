# ══════════════════════════════════════════════════════════════════
#  DAST NEWGEN'SPARK — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
#  NE JAMAIS COMMITTER LE FICHIER .env
# ══════════════════════════════════════════════════════════════════

# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=changez-cette-cle-secrete-en-production-minimum-50-caracteres
DEBUG=False
ALLOWED_HOSTS=dastdigital.com,www.dastdigital.com
SITE_URL=https://dastdigital.com

# ── Base de données Supabase (PostgreSQL) ────────────────────────
# Récupérer ces valeurs dans : Supabase → Settings → Database
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_supabase
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432

# ── Supabase Storage (pour les images uploadées) ────────────────
# Récupérer dans : Supabase → Settings → API
USE_SUPABASE_STORAGE=True
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key
SUPABASE_STORAGE_BUCKET=dast-media
# Récupérer dans : Supabase → Settings → Storage → S3 Connection
AWS_ACCESS_KEY_ID=votre_storage_access_key
AWS_SECRET_ACCESS_KEY=votre_storage_secret_key
AWS_S3_ENDPOINT_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co/storage/v1/s3
AWS_S3_REGION_NAME=auto

# ── Email professionnel ──────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=contact@dastdigital.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application
DEFAULT_FROM_EMAIL=DAST NEWGEN'SPARK <contact@dastdigital.com>
CONTACT_EMAIL=contact@dastdigital.com

# ── Super Administrateur (création automatique au 1er démarrage) ─
SUPER_ADMIN_USERNAME=dast_owner
SUPER_ADMIN_EMAIL=contact@dastdigital.com
SUPER_ADMIN_PASSWORD=MotDePasseTresSécurisé123!
SUPER_ADMIN_FIRST_NAME=SABY
SUPER_ADMIN_LAST_NAME=Ange Noël

# ── Analytics (optionnel) ────────────────────────────────────────
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
